# Copy this file to .env.local and fill in your project-specific values.
# Never commit actual credentials — set them in your environment or GitHub secrets/variables.

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Frontend (Next.js / GitHub Actions build) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Server-side / GitHub Actions (never expose to the browser) ───────────────
SUPABASE_URL=https://your-project-ref.supabase.co
# Set in local .env.local or GitHub Actions secret only; never commit the value.
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional integrations ────────────────────────────────────────────────────
# VITE_WATCHCHARTS_API_KEY=
# RESEND_API_KEY=
