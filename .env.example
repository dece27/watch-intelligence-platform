# Copy this file to .env.local and fill in your project-specific values.
# Never commit actual credentials — set them in your environment or GitHub secrets/variables.

# ── Supabase (all contexts) ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Browser/runtime preferred names (Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Server-side / GitHub Actions only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional integrations ────────────────────────────────────────────────────
# VITE_WATCHCHARTS_API_KEY=
# RESEND_API_KEY=
